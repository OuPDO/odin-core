# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=generate-a-random-secret
ODIN_ALLOWED_USERS=your-telegram-user-id

# LLM Provider: openrouter, anthropic, azure, vertex
LLM_PROVIDER=openrouter
LLM_API_KEY=your-openrouter-key
LLM_BASE_URL=https://openrouter.ai/api/v1
# Models (OpenRouter format: provider/model-name)
LLM_MODEL_ROUTER=anthropic/claude-haiku-4-5-20251001
LLM_MODEL_DEFAULT=anthropic/claude-sonnet-4-20250514
LLM_MODEL_ANALYSIS=anthropic/claude-opus-4-20250514

# Supabase
SUPABASE_URL=https://supabase.oblm.de
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
DATABASE_URL=postgresql://postgres:password@supabase-db:5432/postgres

# Qdrant
QDRANT_URL=https://qdrant.oblm.de
QDRANT_API_KEY=your-qdrant-api-key

# n8n Webhooks
N8N_OM_URL=https://n8n-om.dobla.biz
N8N_OM_API_KEY=generate-api-key
N8N_ADO_URL=https://n8n-ado.dobla.biz
N8N_ADO_API_KEY=generate-api-key

# ODIN
ODIN_ENVIRONMENT=production
ODIN_LOG_LEVEL=INFO
